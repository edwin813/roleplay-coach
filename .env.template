# API Keys and Environment Variables
# Copy this file to .env and fill in your actual values

# Anthropic API (REQUIRED for conversation management)
ANTHROPIC_API_KEY=

# Voice Services (choose one or both)
# Option 1: Deepgram for speech-to-text (recommended)
DEEPGRAM_API_KEY=

# Option 2: Google Cloud credentials (for TTS)
# Set GOOGLE_APPLICATION_CREDENTIALS path or use credentials.json

# Option 3: ElevenLabs for natural TTS (optional, higher quality)
ELEVENLABS_API_KEY=

# Google Sheets (for training session logs)
GOOGLE_SHEETS_TRAINING_LOG_ID=

# Slack (for trainer notifications)
SLACK_WEBHOOK_URL=

# Modal (for webhooks - optional)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Manager backend (Flask session secret — set to any long random string)
MANAGER_SESSION_SECRET=

# Add other API keys as needed
